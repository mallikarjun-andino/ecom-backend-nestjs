{
  "name": "catalyst-api",
  "version": "0.0.1",
  "description": "API for Catalyst app",
  "author": "Architect @AndinoLabs",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npx openapi-generate --output ./generated && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "NODE_ENV=development node --require tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start",
    "start:debug": "NODE_ENV=local node --require tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:local": "NODE_ENV=local node --require tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start",
    "start:local-otel": "NODE_ENV=local node --require ts-node/register --require tsconfig-paths/register --require ./dist/src/otel.bootstrap.js dist/src/main.js",
    "start:prod": "NODE_ENV=production node --require tsconfig-paths/register --require ./dist/src/otel.bootstrap.js dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "depcruise:graph": "depcruise src --include-only '^src' --exclude '(migrations|\\.spec\\.ts$)' --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dependency-graph.svg",
    "depcruise:archi": "depcruise src --include-only '^src' --exclude '(migrations|\\.spec\\.ts$)' --config .dependency-cruiser.cjs --output-type archi | dot -T svg > architecture-graph.svg",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.911.0",
    "@aws-sdk/client-sqs": "^3.914.0",
    "@fastify/static": "^8.2.0",
    "@snow-tzu/nest-sqs-listener": "^0.0.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.64.6",
    "@opentelemetry/sdk-node": "^0.205.0",
    "axios": "^1.12.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.4.1",
    "opossum": "^9.0.0",
    "pg": "^8.16.3",
    "pino": "^10.0.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@snow-tzu/nest-openapi-code-generator": "^0.0.11",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dependency-cruiser": "^17.1.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@shared$": "<rootDir>/shared/index",
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@generated/(.*)$": "<rootDir>/generated/$1",
      "^@generated$": "<rootDir>/generated/index"
    }
  }
}
